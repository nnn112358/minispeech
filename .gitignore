# Python
__pycache__/
*.py[cod]
.DS_Store
.venv/
*.venv/

# Trained models / data / generated outputs — NOT committed.
# Bring your own JSUT data; publish checkpoints & axmodels via GitHub Releases.
checkpoints/
data/
fs/
fs_data/
outputs/
_legacy/
# _unused/ holds the archived SqueezeWave codebase, intentionally tracked (see README).

# NPU: keep only the *.json Pulsar2 config templates; ignore all build
# artifacts & calibration data (output*/, model/, dataset/, calib_*/ — some root-owned)
npu/*
!npu/*.json

# stray binaries
*.pth
*.onnx
*.onnx.data
*.axmodel
*.s16
*.f32

# transient run artifacts
logs/
*.log
onnxruntime_profile_*.json
